{
  "name": "latam-en-datos",
  "version": "1.0.0",
  "description": "Plataforma de datos georreferenciados para investigación educativa",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:official-data": "node scripts/build-official-open-data.js",
    "db:backup": "powershell -ExecutionPolicy Bypass -File ./scripts/db-backup-restore.ps1 -Mode backup",
    "db:restore": "powershell -ExecutionPolicy Bypass -File ./scripts/db-backup-restore.ps1 -Mode restore"
  },
  "keywords": [
    "nodejs",
    "openstreetmap",
    "maslow",
    "ods",
    "investigacion"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.5",
    "multer": "^2.0.2",
    "socket.io": "^4.8.1"
  }
}